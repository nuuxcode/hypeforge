# Gemini API keys. One key is enough; numbered backups enable automatic rotation.
GEMINI_API_KEY=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# Legacy single-key fallback used only when no key above is set.
# HYPEFORGE_GEMINI_API_KEY=

# Model roles. Optional; without them the app uses gemini-3.1-flash-lite.
# The Settings dialog can also switch models per request from a predefined list.
GEMINI_MODEL_MAIN=gemini-3.1-flash-lite
GEMINI_MODEL_BACKUP=gemini-3-flash-preview
GEMINI_MODEL_VALIDATOR=gemini-3.1-flash-lite
GEMINI_TIMEOUT_MS=25000

# Private prompt-improvement logs. Failed drafts are stored without raw subject details.
HYPEFORGE_CAPTURE_AI_FAILURES=false
# Include redacted server stack traces in the private admin logs.
HYPEFORGE_DEBUG_STACKS=false
# Local fallback when Vercel Blob is unavailable.
# HYPEFORGE_FAILURE_LOG_PATH=.data/hypeforge-ai-failures.ndjson

# Private diagnostics dashboard at /admin. Use independent random values.
HYPEFORGE_ADMIN_CODE=
HYPEFORGE_ADMIN_SESSION_SECRET=

# Cookie rate limit
RATELIMIT_SECRET=
DAILY_LIMIT=20

# Public site URL used for canonical, sitemap, and social metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Durable production storage for shares and diagnostics logs (Upstash Redis).
# Without these, shares and logs fall back to a local .data/ file.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: place shared decks on a persistent disk instead of Redis.
# HYPEFORGE_SHARE_STORE_PATH=/var/lib/hypeforge/shares.json
